{
  "name": "flac-music",
  "version": "2.4.1",
  "description": "FLAC Music - 高品质音乐批量下载客户端",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --mac",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,css,html}\"",
    "test": "node --test --test-name-pattern=\".*\" tests/unit/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "test:coverage": "c8 --reporter=text --reporter=lcov --reporter=html --check-coverage --lines=70 --functions=70 --branches=60 node --test tests/unit/*.test.js",
    "test:coverage:html": "c8 --reporter=html node --test tests/unit/*.test.js",
    "size": "size-limit",
    "commitlint": "commitlint --edit",
    "prepare": "husky || true",
    "release": "release-it"
  },
  "author": "FLAC Music Team",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^21.0.2",
    "@release-it/conventional-changelog": "^8.0.0",
    "@size-limit/file": "^11.0.0",
    "c8": "^10.1.3",
    "electron": "^42.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-config-standard": "^17.0.0",
    "husky": "^9.0.0",
    "prettier": "^3.0.0",
    "release-it": "^17.0.0",
    "size-limit": "^11.0.0"
  },
  "build": {
    "appId": "cn.music.hi.flac",
    "productName": "FLAC Music",
    "copyright": "Copyright © 2025 FLAC Music",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Minions777",
        "repo": "flac-music",
        "releaseType": "release"
      }
    ],
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/renderer/assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FLAC Music"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "src/renderer/assets/icon.icns",
      "category": "public.app-category.music",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "dmg": {
      "title": "FLAC Music ${version}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
